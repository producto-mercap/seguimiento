<aside class="sidebar" id="sidebar">
    <div class="sidebar-icon-collapsed">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" style="width: 24px; height: 24px;">
            <path d="M3 18h18v-2H3v2zm0-5h18v-2H3v2zm0-7v2h18V6H3z"/>
        </svg>
    </div>
    <nav class="sidebar-nav">
        <div class="sidebar-section">
            <a href="/"
               class="nav-item <%= activeMenu === 'seguimiento' ? 'active' : '' %>"
               data-tooltip="Seguimiento">
                <span>Seguimiento</span>
            </a>
        </div>

        <div class="sidebar-divider"></div>

        <a href="/sync" class="nav-item <%= activeMenu === 'sync' ? 'active' : '' %>" data-tooltip="Sync - Equipos">
            <span>Sync - Equipos</span>
        </a>

        <% if (typeof isAdmin !== 'undefined' && isAdmin) { %>
        <a href="/admin" class="nav-item <%= activeMenu === 'admin' ? 'active' : '' %>" data-tooltip="Administración">
            <svg class="nav-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
                <path d="M19.14 12.94c.04-.3.06-.61.06-.94 0-.32-.02-.64-.07-.94l2.03-1.58c.18-.14.23-.41.12-.61l-1.92-3.32c-.12-.22-.37-.29-.59-.22l-2.39.96c-.5-.38-1.03-.7-1.62-.94L14.4 2.81c-.04-.24-.24-.41-.48-.41h-3.84c-.24 0-.43.17-.47.41l-.36 2.54c-.59.24-1.13.57-1.62.94l-2.39-.96c-.22-.08-.47 0-.59.22L2.74 8.87c-.12.21-.08.47.12.61l2.03 1.58c-.05.3-.09.63-.09.94s.02.64.07.94l-2.03 1.58c-.18.14-.23.41-.12.61l1.92 3.32c.12.22.37.29.59.22l2.39-.96c.5.38 1.03.7 1.62.94l.36 2.54c.05.24.24.41.48.41h3.84c.24 0 .44-.17.47-.41l.36-2.54c.59-.24 1.13-.56 1.62-.94l2.39.96c.22.08.47 0 .59-.22l1.92-3.32c.12-.22.07-.47-.12-.61l-2.01-1.58zM12 15.6c-1.98 0-3.6-1.62-3.6-3.6s1.62-3.6 3.6-3.6 3.6 1.62 3.6 3.6-1.62 3.6-3.6 3.6z"/>
            </svg>
            <span>Administración</span>
        </a>
        <% } %>
    </nav>
</aside>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        const sidebar = document.getElementById('sidebar');
        const mainContent = document.querySelector('.main-content');
        if (sidebar && mainContent) {
            const sidebarWidth = getComputedStyle(document.documentElement).getPropertyValue('--sidebar-width').trim() || '190px';
            const tieneProducto = '<%= typeof productoActual !== "undefined" && productoActual ? String(productoActual) : "" %>' !== '';
            const tieneEquipo = '<%= typeof equipoActual !== "undefined" ? String(equipoActual || "") : "" %>' !== '';
            if (tieneProducto && tieneEquipo) {
                sidebar.classList.add('contraido');
                mainContent.style.marginLeft = '64px';
                mainContent.style.width = 'calc(100% - 64px)';
                mainContent.style.maxWidth = 'calc(100% - 64px)';
            } else {
                sidebar.classList.remove('contraido');
                mainContent.style.marginLeft = sidebarWidth;
                mainContent.style.width = 'calc(100% - ' + sidebarWidth + ')';
                mainContent.style.maxWidth = 'calc(100% - ' + sidebarWidth + ')';
            }
        }
    });
</script>

<style>
    .sidebar-section { margin-bottom: 8px; }
    .sidebar-divider {
        height: 1px;
        background: var(--border-color);
        margin: 8px 16px;
    }
    .sidebar.contraido .sidebar-divider { margin: 8px 8px; }
</style>
